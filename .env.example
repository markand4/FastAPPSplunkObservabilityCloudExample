# ─────────────────────────────────────────────────────────────
# Splunk Observability Cloud Configuration
# ─────────────────────────────────────────────────────────────

# Your Splunk O11y Cloud ingest token (REQUIRED)
SPLUNK_ACCESS_TOKEN=your-splunk-ingest-token-here

# Your Splunk realm  (e.g. us0, us1, us2, eu0, jp0, au0)
SPLUNK_REALM=us0

# ─────────────────────────────────────────────────────────────
# OpenTelemetry Settings
# ─────────────────────────────────────────────────────────────

# Service identity
OTEL_SERVICE_NAME=fastapi-websocket-demo
OTEL_ENVIRONMENT=demo

# (Optional) Override OTLP endpoints — defaults point to Splunk ingest
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://ingest.us0.signalfx.com:443
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://ingest.us0.signalfx.com:443
